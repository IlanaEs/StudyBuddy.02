VITE_API_BASE_URL=http://localhost:4000
VITE_SUPABASE_URL=https://ucptoyqlsysnxfjgqttq.supabase.co
VITE_SUPABASE_ANON_KEY=
# Enable Admin QA Mode (never set to true in production unless intentional)
VITE_ENABLE_ADMIN_QA_MODE=

# ── Staging DEMO mode (STAGING ONLY — never set any of these on production) ──
# Auto-populates the dashboard seed and auto-logs-in a pre-issued demo teacher so
# the bare staging link opens straight into a populated dashboard. Hard-gated to
# the staging host below: even if the flag leaks, it only runs when the page is
# served from VITE_DEMO_STAGING_HOST. See src/demo/demoMode.ts.
VITE_ENABLE_DEMO_SEED=
# The exact hostname of the stable staging alias (e.g. studybuddy-staging.vercel.app).
# Must equal window.location.hostname on staging; anything else disables demo mode.
VITE_DEMO_STAGING_HOST=
# Pre-issued demo-teacher session tokens (throwaway, staging Supabase only). Sign the
# demo teacher in once, copy the session's access/refresh tokens here, rotate after.
VITE_DEMO_SESSION_AT=
VITE_DEMO_SESSION_RT=
