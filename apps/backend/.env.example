NODE_ENV=development
STUDYBUDDY_ENV=local
# Required only when STUDYBUDDY_ENV=development targets a non-local Supabase URL.
CONFIRM_REMOTE_DEVELOPMENT_USER_RESET=
HOST=127.0.0.1
PORT=4000
# Comma-separated allowed origins for CORS. Both localhost and 127.0.0.1 variants
# are auto-added for each entry, so a single value is usually sufficient.
FRONTEND_ORIGIN=http://localhost:3001
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Google OAuth (configure in Supabase dashboard -> Authentication -> Providers -> Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Admin Google email (for bootstrap-admin.mjs to identify the admin account)
ADMIN_GOOGLE_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
TEST_USERS_BOOTSTRAP_PASSWORD=
TEACHER_BOOTSTRAP_PASSWORD=
PARENT_BOOTSTRAP_PASSWORD=
# Enable Admin QA Mode (never set to true in production unless intentional)
ENABLE_ADMIN_QA_MODE=
# Local QA only — auto-confirm new signups so onboarding/signup work without
# Supabase email delivery. Hard-gated: ignored unless NODE_ENV !== production.
# NEVER set this in production.
DEV_AUTH_BYPASS=true
