NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Backend-owned Google Calendar OAuth.
# Reuse the same Google OAuth client configured in Supabase, but you MUST add
# this redirect URI to that client's "Authorized redirect URIs" in Google Cloud
# Console: http://localhost:4000/api/teachers/me/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/teachers/me/calendar/callback
# base64-encoded 32 random bytes — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=
# Optional: HMAC secret for the OAuth state param (defaults to service role key).
CALENDAR_OAUTH_STATE_SECRET=
