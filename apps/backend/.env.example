NODE_ENV=development
STUDYBUDDY_ENV=local
# Required only when STUDYBUDDY_ENV=development targets a non-local Supabase URL.
CONFIRM_REMOTE_DEVELOPMENT_USER_RESET=
HOST=127.0.0.1
PORT=4000
FRONTEND_ORIGIN=http://localhost:3001
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
ADMIN_BOOTSTRAP_PASSWORD=
# Enable Admin QA Mode (never set to true in production unless intentional)
ENABLE_ADMIN_QA_MODE=
