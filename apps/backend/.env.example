NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Google Calendar OAuth (backend-owned) ──────────────────────────────────────
# Reuses the same Google OAuth client as Supabase (same client_id).
# GOOGLE_CLIENT_SECRET must be filled — find it in Google Cloud Console.
# REQUIRED: Also register http://localhost:4000/api/teachers/me/calendar/callback
# as an Authorized redirect URI in the Google Cloud Console OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/teachers/me/calendar/callback
# base64-encoded 32 random bytes — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=
# Optional: HMAC secret for the OAuth state param (defaults to service role key).
CALENDAR_OAUTH_STATE_SECRET=
