{
  "name": "studybuddy-02",
  "version": "0.1.0",
  "private": true,
  "description": "StudyBuddy.02 monorepo foundation.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "npm run dev --workspace @studybuddy/backend & npm run dev --workspace @studybuddy/frontend",
    "dev:frontend": "npm run dev --workspace @studybuddy/frontend",
    "dev:backend": "npm run dev --workspace @studybuddy/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
